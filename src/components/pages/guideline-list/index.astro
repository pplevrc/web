---
import PageHeading from "@components/decoratives/Headings/PageHeading.astro";
import type { Guideline } from "@content/guidelines";
import GuidelineList from "./GuidelineList/GuidelineList.astro";

interface Props {
  title: string;
  thumbnail: ImageMetadata | string;
  guidelines: Guideline[];
}

const { title, thumbnail, guidelines } = Astro.props;
---

<PageHeading img={thumbnail}> {title} </PageHeading>
<GuidelineList guidelines={guidelines} />
