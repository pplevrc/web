---
import type { HTMLAttributes } from "astro/types";
import Medium from "./medium/Medium.astro";
import Small from "./small/Small.astro";
import type { CommonProps } from "./type";

export interface Props extends CommonProps, HTMLAttributes<"figure"> {
  size: "small" | "medium";
}

const { size, ...avatarImageProps } = Astro.props;

const Component = {
  small: Small,
  medium: Medium,
}[size];
---

<Component {...avatarImageProps} />
