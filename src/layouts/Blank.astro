---
import "@assets/css/index.css";
import "@styles/styles.css";

import {
  type DescriptionMetaProps,
  default as HeadMeta,
  type OGPProps,
  type SNSProps,
} from "@components/layouts/HeadMeta";
import type { OGPMetadata } from "@components/layouts/HeadMeta/internals/ogpType";
import TemplateDefinition from "@components/layouts/TemplateDefinition/TemplateDefinition.astro";
import type { ColorThemeBase, SocialLinkType } from "@content/commons";
import { css } from "@styles/css";
import type { NodeObject } from "jsonld";

interface Props {
  headMeta: DescriptionMetaProps;
  ogp?: OGPProps;
  sns?: SNSProps;
  jsonLd?: NodeObject | NodeObject[];
  themeColor?: ColorThemeBase;
  polyfill?: {
    invokers?: boolean;
    anchorPosition?: boolean;
  };
  /**
   * 検索エンジンにインデックスさせないか
   */
  noindex?: boolean;

  /**
   *
   */
  rootClass?: string;

  /**
   *
   */
  "rootClass:list"?: string[];

  /**
   *
   */
  defineLogos?: SocialLinkType[];
}

const {
  headMeta: { title, description, keywords },
  ogp,
  sns,
  jsonLd,
  themeColor,
  polyfill,
  noindex,
  rootClass,
  "rootClass:list": rootClassList = [],
  defineLogos,
} = Astro.props;

// OGPProps から OGPMetadata に変換（url を追加）
const ogpMetadata: OGPMetadata | undefined = ogp
  ? {
      ...(ogp as Omit<OGPMetadata, "url">),
      url: Astro.url.href,
    }
  : undefined;
---

<!doctype html>
<html lang="ja" dir="ltr">
  <head>
    <slot name="head" />
    <HeadMeta
      title={title}
      description={description}
      keywords={keywords}
      polyfill={polyfill}
      themeColor={themeColor ?? "smoke"}
      noindex={noindex}
      ogp={ogpMetadata}
      sns={sns}
      jsonLd={jsonLd}
    />
  </head>
  <body class:list={[
    css({ w: "full", h: "full" }),
    rootClass,
    ...rootClassList,
  ]}>
    <TemplateDefinition defineLogos={defineLogos}/>
    <slot />
  </body>
</html>
